# Copy to .env and adjust. Docker Compose sets many of these inline for local dev.

# Backend (FastAPI / pydantic-settings)
# ENVIRONMENT=local|development|production — in production, SECRET_KEY must not be "change-me".
ENVIRONMENT=development
SECRET_KEY=change-me
DATABASE_URL=postgresql+psycopg2://atlas:atlas@localhost:15432/atlas
# Optional: comma-separated CORS origins. Leave empty for built-in localhost defaults.
# CORS_ORIGINS=http://localhost:13000,http://127.0.0.1:13000

# Seed (docker-compose overrides)
# ATLAS_SEED_ADMIN_EMAIL=
# ATLAS_SEED_ADMIN_PASSWORD=

# Frontend (build-time for NEXT_PUBLIC_*)
# Direct UI to API: http://localhost:18080
# Same-origin via Nginx proxy: http://localhost:18090/api
# NEXT_PUBLIC_API_URL=http://localhost:18080
